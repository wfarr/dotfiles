[alias]
	st = status --short --branch
	lp = log --patch
	dc = diff --cached
	co = checkout
	ci = commit
	di = diff
	ack = grep --break --heading --line-number
	current-branch = rev-parse --abbrev-ref HEAD
	pb = "!git push -u origin $(git current-branch)"

[init]
  defaultBranch = main

[color]
	ui = true
	[grep]
		filename = bold green
		match = black yellow

